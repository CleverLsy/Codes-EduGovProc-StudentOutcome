library(duckdb)
dbfile <-  "~/Library/CloudStorage/OneDrive-个人/4 数据库/政府采购数据/WKdata/GovProc.duckdb"
con<- dbConnect(duckdb(), dbfile)
# Step 1 追加新变量 EduProcType
dbExecute(con, "ALTER TABLE EduGovProc_IT ADD COLUMN IF NOT EXISTS EduProcType INTEGER DEFAULT 4")
# Step 2 定义关键词列表
keyWordForEduITProc_Infrastucture <- c("硬件", "设备", "计算机", "服务器", "交换机", "路由器","防火墙", "电子白板", "投影仪", "触控一体机", "智能终端", "显示器", "LED", "液晶", "教室设备","网络", "互联网", "校园网", "光纤", "宽带", "带宽", "无线",  "WiFi", "5G", "数据中心", "机房建设", "网络设备")
keyWordForEduITProc_DigitalResource <- c("软件", "系统", "管理系统", "ERP", "应用程序", "操作系统", "数据库", "信息系统", "教学系统", "虚拟化", "云计算", "人工智能", "AI",  "数字资源", "电子书", "电子教材", "数字图书馆", "在线课程", "慕课", "在线学习", "虚拟现实", "增强现实", "VR", "AR", "多媒体资源", "内容管理系统")
keyWordForEduProc_Training <- c("培训", "信息素养", "教师培训", "技能培训", "在线培训",
"远程培训", "教育培训")
# Step 3 构造 LIKE OR 语句
Infrastucture_conditions <- paste0("合同名称 LIKE '%", keyWordForEduProc_Infrastucture, "%' OR 主要标的名称 LIKE '%", keyWordForEduProc_Infrastucture, "%'",collapse = " OR ")
library(duckdb)
dbfile <-  "~/Library/CloudStorage/OneDrive-个人/4 数据库/政府采购数据/WKdata/GovProc.duckdb"
con<- dbConnect(duckdb(), dbfile)
# Step 1 追加新变量 EduProcType
dbExecute(con, "ALTER TABLE EduGovProc_IT ADD COLUMN IF NOT EXISTS EduProcType INTEGER DEFAULT 4")
# Step 2 定义关键词列表
keyWordForEduITProc_Infrastucture <- c("硬件", "设备", "计算机", "服务器", "交换机", "路由器","防火墙", "电子白板", "投影仪", "触控一体机", "智能终端", "显示器", "LED", "液晶", "教室设备","网络", "互联网", "校园网", "光纤", "宽带", "带宽", "无线",  "WiFi", "5G", "数据中心", "机房建设", "网络设备")
keyWordForEduITProc_DigitalResource <- c("软件", "系统", "管理系统", "ERP", "应用程序", "操作系统", "数据库", "信息系统", "教学系统", "虚拟化", "云计算", "人工智能", "AI",  "数字资源", "电子书", "电子教材", "数字图书馆", "在线课程", "慕课", "在线学习", "虚拟现实", "增强现实", "VR", "AR", "多媒体资源", "内容管理系统")
keyWordForEduITProc_Training <- c("培训", "信息素养", "教师培训", "技能培训", "在线培训",
"远程培训", "教育培训")
# Step 3 构造 LIKE OR 语句
Infrastucture_conditions <- paste0("合同名称 LIKE '%", keyWordForEduITProc_Infrastucture, "%' OR 主要标的名称 LIKE '%", keyWordForEduITProc_Infrastucture, "%'",collapse = " OR ")
DigitalResource_conditions <- paste0(
"合同名称 LIKE '%", keyWordForEduITProc_DigitalResource, "%' OR 主要标的名称 LIKE '%",
keyWordForEduITProc_DigitalResource, "%'", collapse = " OR "
)
Training_conditions <- paste0(
"合同名称 LIKE '%", keyWordForEduITProc_Training, "%' OR 主要标的名称 LIKE '%",
keyWordForEduITProc_Training, "%'", collapse = " OR "
)
# Step 4 更新 EduProcType 变量
# **1. 硬件 & 网络建设 (EduProcType = 1)**
dbExecute(con, paste0("
UPDATE EduGovProc_IT
SET EduProcType = 1
WHERE ", Infrastucture_conditions, "
"))
# **2. 软件 & 数字资源 (EduProcType = 2)**
dbExecute(con, paste0("
UPDATE EduGovProc_IT
SET EduProcType = 2
WHERE ", DigitalResource_conditions, "
"))
# **3. 教师培训 (EduProcType = 3)**
dbExecute(con, paste0("
UPDATE EduGovProc_IT
SET EduProcType = 3
WHERE ", Training_conditions, "
"))
# **Step 5: 确保 EduProcType 变量已更新**
edu_proc_counts <- dbGetQuery(con, "SELECT EduProcType, COUNT(*) as count FROM EduGovProc_IT GROUP BY EduProcType ORDER BY EduProcType")
print(edu_proc_counts)
# 断开数据库连接
dbDisconnect(con, shutdown = TRUE)
rm(list=ls())
